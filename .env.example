# Django Settings
# SECURITY: Copy this file to .env and fill in actual values
# NEVER commit .env to version control

# Security - Keep this SECRET and unique
SECRET_KEY=your-secret-key-here

# Debug Mode - Set to False in production
DEBUG=False

# Allowed Hosts - Comma-separated list of allowed host/domain names
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (optional - you can use SQLite by default)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=mydb
# DB_USER=myuser
# DB_PASSWORD=mypassword
# DB_HOST=localhost
# DB_PORT=5432
